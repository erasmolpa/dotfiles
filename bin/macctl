#!/usr/bin/env bash
# macctl — single CLI entrypoint (plan / apply / doctor / sync / import / lint)
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# If DOTFILES is set but invalid (e.g. symlinked macctl), fall back to repo root.
if [[ -z "${DOTFILES:-}" || ! -f "${DOTFILES}/core/main.sh" ]]; then
  export DOTFILES="$ROOT"
fi
exec bash "${DOTFILES}/core/main.sh" "$@"
